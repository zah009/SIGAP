#-------------------------
# Operating Specific Junk Files
#-------------------------

# OS X
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows image file caches
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

#-------------------------
# Environment Files
#-------------------------
.env
.vagrant
Vagrantfile

#-------------------------
# Writable folders — simpan struktur folder, buang isinya
#-------------------------
/writable/cache/*
!/writable/cache/.gitkeep

/writable/logs/*
!/writable/logs/.gitkeep

/writable/session/*
!/writable/session/.gitkeep

/writable/debugbar/*
!/writable/debugbar/.gitkeep

/writable/uploads/*
!/writable/uploads/.gitkeep

!/writable/.htaccess
!/writable/index.html

php_errors.log

#-------------------------
# User Guide Temp Files
#-------------------------
/user_guide_src/build/*
/user_guide_src/cilexer/build/*
/user_guide_src/cilexer/dist/*
/user_guide_src/cilexer/pycilexer.egg-info/*

#-------------------------
# Test Files
#-------------------------
/tests/coverage*
/phpunit

#-------------------------
# Composer
#-------------------------
vendor/

#-------------------------
# IDE / Development Files
#-------------------------
_modules/*
.php-version
.idea/
*.iml
/nbproject/
/build/
/nbbuild/
/dist/
/nbdist/
/nbactions.xml
/nb-configuration.xml
/.nb-gradle/
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project
.phpintel
/api/
.vscode/

/results/
/phpunit.xml
*.exe

#-------------------------
# Upload lampiran tiket
#-------------------------
public/uploads/tickets/*
!public/uploads/tickets/.gitkeep